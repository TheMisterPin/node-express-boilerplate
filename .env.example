# Runtime environment: development | production | test
NODE_ENV=development

# HTTP port the API listens on
PORT=3000

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erpdb?schema=public"

# JWT signing secret for access tokens (min 32 characters)
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# JWT signing secret for refresh tokens (min 32 characters)
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-32-chars

# Access token expiry (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES=15m

# Refresh token expiry (e.g. 7d)
JWT_REFRESH_EXPIRES=7d

# bcrypt salt rounds (default 12)
BCRYPT_SALT_ROUNDS=12

# Global rate limit window in milliseconds (default 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window for global limiter
RATE_LIMIT_MAX=100

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Seed admin user email (used by prisma/seed.ts)
SEED_ADMIN_EMAIL=admin@demo.local

# Seed admin user password (used by prisma/seed.ts)
SEED_ADMIN_PASSWORD=ChangeMe123!

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  url = env("DATABASE_URL")
  provider = "sqlserver"
}

model Request {
  id                   Int         @id @default(autoincrement())
  title                String
  description          String
  status               String      @default("OPEN")
  assignedTechnician   Technician? @relation("AssignedRequests", fields: [assignedTechnicianId], references: [id])
  assignedTechnicianId Int?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  technician           Technician? @relation("TechnicianRequests", fields: [technicianId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  technicianId         Int?
}

model Technician {
  id                 Int       @id @default(autoincrement())
  name               String
  email              String    @unique
  phone              String
  requests           Request[] @relation("AssignedRequests")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  technicianRequests Request[] @relation("TechnicianRequests")
}

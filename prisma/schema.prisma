generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  users       User[]
  roles       Role[]
  permissions Permission[]
  auditLogs   AuditLog[]
  categories  Category[]
  products    Product[]

  @@index([deletedAt])
}

model User {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  email        String
  passwordHash String
  name         String?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  sessions Session[]

  @@unique([organizationId, email])
  @@index([organizationId, deletedAt])
}

model Role {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  description String?
  isSystem    Boolean @default(false)

  users       User[]
  permissions Permission[]

  @@unique([organizationId, name])
  @@index([organizationId, deletedAt])
}

model Permission {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])
  resource String
  action   String

  @@unique([roleId, resource, action])
  @@index([organizationId, deletedAt])
}

model Session {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  refreshToken   String    @unique
  accessTokenJti String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?

  @@index([userId, deletedAt])
  @@index([accessTokenJti])
}

model AuditLog {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  model    String
  action   String
  recordId String
  actorId  String?
  before   Json?
  after    Json?

  @@index([organizationId, deletedAt])
  @@index([recordId])
}

model Category {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  slug        String
  description String?

  products Product[]

  @@unique([organizationId, slug])
  @@index([organizationId, deletedAt])
}

model Product {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  sku         String
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)

  @@unique([organizationId, sku])
  @@index([organizationId, deletedAt])
  @@index([categoryId])
}
